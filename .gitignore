### Project Specific ###

# Metamod files
# Ignore all unrelated/unneeded Metamod files
dist/**/addons/metamod/README.txt
dist/*/addons/metamod/**/metamod.2.*.so
!dist/*/addons/metamod/**/metamod.2.hl2dm.so
!dist/*/addons/metamod/**/metamod.2.sdk2013.so
!dist/*/addons/metamod/**/metamod.2.tf2.so


# SourceMod files
# Ignore all unrelated/unneeded SourceMod files
dist/*/addons/sourcemod/GPL*.txt
dist/*/addons/sourcemod/LICENSE.txt
dist/*/addons/sourcemod/**/*.alienswarm.so
dist/*/addons/sourcemod/**/*.blade.so
dist/*/addons/sourcemod/**/*.bms.so
dist/*/addons/sourcemod/**/*.contagion.so
dist/*/addons/sourcemod/**/*.csgo.so
dist/*/addons/sourcemod/**/*.css.so
dist/*/addons/sourcemod/**/*.darkm.so
dist/*/addons/sourcemod/**/*.dods.so
dist/*/addons/sourcemod/**/*.doi.so
dist/*/addons/sourcemod/**/*.ep1.so
dist/*/addons/sourcemod/**/*.ep2.so
dist/*/addons/sourcemod/**/*.insurgency.so
dist/*/addons/sourcemod/**/*.l4d.so
dist/*/addons/sourcemod/**/*.l4d2.so
dist/*/addons/sourcemod/**/*.mcv.so
dist/*/addons/sourcemod/**/*.nd.so
dist/*/addons/sourcemod/**/*.pvkii.so

# Plugins we don't want
dist/*/addons/sourcemod/plugins/disabled
dist/*/addons/sourcemod/plugins/funcommands.smx
dist/*/addons/sourcemod/plugins/funvotes.smx
dist/*/addons/sourcemod/plugins/nextmap.smx
dist/*/addons/sourcemod/plugins/sounds.smx




